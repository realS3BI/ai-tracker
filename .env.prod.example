NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_BIND_PORT=3000

# Generate with: pnpm hash-password "your-password" (SHA-256 + base64)
APP_PASSWORD_HASH=
APP_SESSION_SECRET=replace-with-long-random-string
APP_TOKEN_SECRET=replace-with-long-random-string
APP_SECURE_COOKIE=true
CLI_TOKEN_TTL_SECONDS=2592000
PROVIDER_TIMEOUT_MS=10000

# Persisted fallback cache inside the container volume
APP_DATA_DIR=/data

# Hosted backend provider secrets
OPENAI_API_KEY=
OPENAI_ORG_ID=
# Optional: enables derived remaining = monthly budget - current month costs
OPENAI_MONTHLY_BUDGET_USD=100
OPENROUTER_API_KEY=
CURSOR_DASHBOARD_COOKIE=
CURSOR_TEAM_ID=-1

# Optional: only needed if the backend container itself should read Codex logs
CODEX_HOME=
# Optional: host path for an extra compose bind mount when you want backend-side Codex access
CODEX_HOST_PATH=
