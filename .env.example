NODE_ENV=production
HOST=0.0.0.0
PORT=3000
# Docker Compose public port mapping (optional)
APP_BIND_PORT=3000

# Generate with: pnpm hash-password "your-password"
APP_PASSWORD_HASH=
APP_SESSION_SECRET=replace-with-long-random-string
APP_TOKEN_SECRET=replace-with-long-random-string
# Keep this true in production behind HTTPS
APP_SECURE_COOKIE=true
CLI_TOKEN_TTL_SECONDS=2592000

OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MONTHLY_BUDGET_USD=100

OPENROUTER_API_KEY=
# Optional path on the backend host or inside the container
CODEX_HOME=

PROVIDER_TIMEOUT_MS=10000
